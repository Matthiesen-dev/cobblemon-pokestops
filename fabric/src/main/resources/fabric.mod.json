{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "license": "${mod_license}",
  "icon": "icon.png",
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.github_releases": "${github_url}"
      }
    }
  },
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.matthiesen.fabric.cobblemon_pokestops.CobblemonPokestopsFabric"
    ],
    "client": [
      "dev.matthiesen.fabric.cobblemon_pokestops.CobblemonPokestopsFabricClient"
    ],
    "fabric-datagen": [
      "dev.matthiesen.fabric.cobblemon_pokestops.datagen.DataGenerator"
    ]
  },
  "depends": {
    "minecraft": "1.21.1",
    "cobblemon": ">=1.7.3 <1.8.0",
    "geckolib": ">=4.8.3 <5.0.0"
  }
}